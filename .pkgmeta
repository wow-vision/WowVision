package-as: WowVision
manual-changelog: changes-latest.md
changelog-markup: markdown

externals:
  libs/LibStub: https://github.com/WoWUIDev/Ace3/LibStub
  libs/CallbackHandler-1.0: https://github.com/WoWUIDev/Ace3/CallbackHandler-1.0
  libs/AceAddon-3.0: https://github.com/WoWUIDev/Ace3/AceAddon-3.0
  libs/AceConsole-3.0: https://github.com/WoWUIDev/Ace3/AceConsole-3.0
  libs/AceEvent-3.0: https://github.com/WoWUIDev/Ace3/AceEvent-3.0
  libs/AceLocale-3.0: https://github.com/WoWUIDev/Ace3/AceLocale-3.0
  libs/LibSharedMedia-3.0: https://github.com/wowace-clone/LibSharedMedia-3.0/LibSharedMedia-3.0
  # LibRangeCheck-3.0 is no longer maintained upstream and needs local patches
  # for Mists Classic (spell-ID range checking), so we vendor it directly
  # instead of fetching it. See libs/LibRangeCheck-3.0/LibRangeCheck-3.0.lua.

ignore:
  - .stylua.toml
  - .gitignore
  - .gitmodules
  - .github
  - .vscode
  - packager
  - changes-latest.md
